{
  "expo": {
    "name": "DeltexApp",
    "slug": "DeltexApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo/Deltex.png",
    "scheme": "deltexapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.DeltexApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-local-authentication",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Deltex AI to analyze screenshots and profile images you choose."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0C12",
          "android": {
            "image": "./assets/images/Logo/Deltex.png",
            "imageWidth": 112
          }
        }
      ],
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
